{
  "openapi": "3.0.0",
  "info": {
    "title": "AI Job Board API",
    "version": "1.0.0",
    "description": "API for the AI Job Board application — browse job titles, search jobs, and submit applications."
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "Local development server"
    }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "admin_session"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        }
      },
      "Title": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "jobs_size": { "type": "integer" }
        }
      },
      "Job": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "title_id": { "type": "integer" },
          "company": { "type": "string" },
          "email": { "type": "string" },
          "location": { "type": "string" },
          "type": { "type": "string" },
          "salary": { "type": "string" },
          "description": { "type": "string" },
          "image_url": { "type": "string" },
          "created_at": { "type": "string" },
          "updated_at": { "type": "string" }
        }
      },
      "Location": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "jobs_size": { "type": "integer" },
          "created_at": { "type": "string" }
        }
      },
      "JobListing": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "external_id": { "type": "string" },
          "title": { "type": "string" },
          "company": { "type": "string" },
          "location": { "type": "string" },
          "job_type": { "type": "string" },
          "salary_range": { "type": "string" },
          "skills": { "type": "array", "items": { "type": "string" } },
          "description": { "type": "string" },
          "apply_url": { "type": "string" },
          "apply_email": { "type": "string" },
          "source": { "type": "string" },
          "expires_at": { "type": "string" },
          "created_at": { "type": "string" }
        }
      },
      "JobListingsPage": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/JobListing" } },
          "total": { "type": "integer" },
          "page": { "type": "integer" },
          "limit": { "type": "integer" },
          "totalPages": { "type": "integer" }
        }
      },
      "Admin": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "email": { "type": "string" },
          "created_at": { "type": "string" }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string" },
          "password": { "type": "string" }
        }
      },
      "TitleCreateRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 }
        }
      },
      "JobCreateRequest": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "company": { "type": "string" },
          "email": { "type": "string" },
          "location": { "type": "string" },
          "type": { "type": "string" },
          "salary": { "type": "string" },
          "description": { "type": "string" },
          "image_url": { "type": "string" }
        }
      },
      "AdminCreateRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string" },
          "password": { "type": "string" }
        }
      },
      "AdminUpdateRequest": {
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "password": { "type": "string" }
        }
      },
      "LocationCreateRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 }
        }
      },
      "JobListingCreateRequest": {
        "type": "object",
        "required": ["title", "company"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "company": { "type": "string", "minLength": 1 },
          "location": { "type": "string" },
          "job_type": { "type": "string" },
          "salary_range": { "type": "string" },
          "skills": { "type": "array", "items": { "type": "string" } },
          "description": { "type": "string" },
          "apply_url": { "type": "string" },
          "apply_email": { "type": "string" },
          "source": { "type": "string" },
          "expires_in_days": { "type": "integer", "minimum": 1, "maximum": 365 }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" }
        }
      }
    }
  },
  "paths": {
    "/titles": {
      "get": {
        "summary": "List all job titles",
        "tags": ["Public"],
        "responses": {
          "200": {
            "description": "Array of job titles",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Title" }
                }
              }
            }
          },
          "429": { "description": "Too many requests" }
        }
      }
    },
    "/jobs": {
      "get": {
        "summary": "Search jobs",
        "description": "Returns jobs, optionally filtered by title keyword.",
        "tags": ["Public"],
        "parameters": [
          {
            "name": "title",
            "in": "query",
            "required": false,
            "description": "Keyword to filter jobs by title (case-insensitive partial match)",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of matching jobs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Job" }
                }
              }
            }
          },
          "429": { "description": "Too many requests" }
        }
      }
    },
    "/apply": {
      "post": {
        "summary": "Submit a job application",
        "description": "Submits an application with resume upload. Accepts multipart/form-data.",
        "tags": ["Public"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "position", "type", "salary", "resume"],
                "properties": {
                  "name": { "type": "string", "minLength": 1, "description": "Applicant full name" },
                  "email": { "type": "string", "format": "email", "description": "Applicant email" },
                  "position": { "type": "string", "minLength": 1, "description": "Job position applied for" },
                  "type": { "type": "string", "minLength": 1, "description": "Job type (e.g. Full-time, Remote)" },
                  "salary": { "type": "string", "minLength": 1, "description": "Expected salary" },
                  "resume": { "type": "string", "format": "binary", "description": "Resume PDF file" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Application submitted successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" }
              }
            }
          },
          "400": { "description": "Validation error" },
          "429": { "description": "Too many requests" }
        }
      }
    },
    "/admin/login": {
      "post": {
        "summary": "Admin login",
        "description": "Authenticate as an admin. Creates a session cookie on success.",
        "tags": ["Admin Auth"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" }
              }
            }
          },
          "400": { "description": "Missing email or password" },
          "401": { "description": "Invalid credentials" },
          "429": { "description": "Too many requests" }
        }
      }
    },
    "/admin/logout": {
      "post": {
        "summary": "Admin logout",
        "description": "Clears the admin session cookie.",
        "tags": ["Admin Auth"],
        "responses": {
          "200": {
            "description": "Logout successful",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" }
              }
            }
          },
          "429": { "description": "Too many requests" }
        }
      }
    },
    "/admin/titles": {
      "get": {
        "summary": "List all titles (admin)",
        "tags": ["Admin - Titles"],
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Array of all titles",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Title" }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "429": { "description": "Too many requests" }
        }
      },
      "post": {
        "summary": "Create a new title",
        "tags": ["Admin - Titles"],
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TitleCreateRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Title created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Title" }
              }
            }
          },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized" },
          "409": { "description": "Title already exists" },
          "429": { "description": "Too many requests" }
        }
      }
    },
    "/admin/admins": {
      "get": {
        "summary": "List all admins",
        "tags": ["Admin - Admins"],
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Array of admin users",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Admin" }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "429": { "description": "Too many requests" }
        }
      },
      "post": {
        "summary": "Create a new admin",
        "tags": ["Admin - Admins"],
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AdminCreateRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Admin created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Admin" }
              }
            }
          },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized" },
          "409": { "description": "Email already exists" },
          "429": { "description": "Too many requests" }
        }
      }
    },
    "/admin/admins/{id}": {
      "put": {
        "summary": "Update an admin",
        "tags": ["Admin - Admins"],
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AdminUpdateRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Admin updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Admin" }
              }
            }
          },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized" },
          "409": { "description": "Email already exists" },
          "429": { "description": "Too many requests" }
        }
      },
      "delete": {
        "summary": "Delete an admin",
        "description": "You cannot delete your own account.",
        "tags": ["Admin - Admins"],
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Admin deleted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Cannot delete own account" },
          "429": { "description": "Too many requests" }
        }
      }
    },
    "/locations": {
      "get": {
        "summary": "List all locations",
        "tags": ["Public"],
        "responses": {
          "200": {
            "description": "Array of locations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Location" }
                }
              }
            }
          }
        }
      }
    },
    "/job-listings": {
      "get": {
        "summary": "Browse job listings with pagination",
        "tags": ["Public"],
        "parameters": [
          { "name": "search", "in": "query", "required": false, "description": "Search by title or company", "schema": { "type": "string" } },
          { "name": "location", "in": "query", "required": false, "description": "Filter by location", "schema": { "type": "string" } },
          { "name": "type", "in": "query", "required": false, "description": "Filter by job type", "schema": { "type": "string" } },
          { "name": "page", "in": "query", "required": false, "description": "Page number (default 1)", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "required": false, "description": "Results per page (default 10, max 50)", "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": {
          "200": {
            "description": "Paginated job listings",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/JobListingsPage" }
              }
            }
          }
        }
      }
    },
    "/admin/locations": {
      "get": {
        "summary": "List all locations (admin)",
        "tags": ["Admin - Locations"],
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Array of locations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Location" }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "429": { "description": "Too many requests" }
        }
      },
      "post": {
        "summary": "Create a new location",
        "tags": ["Admin - Locations"],
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LocationCreateRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Location created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Location" }
              }
            }
          },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized" },
          "409": { "description": "Location already exists" },
          "429": { "description": "Too many requests" }
        }
      }
    },
    "/admin/job-listings": {
      "get": {
        "summary": "List all job listings (admin)",
        "tags": ["Admin - Job Listings"],
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Array of job listings",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/JobListing" }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "429": { "description": "Too many requests" }
        }
      },
      "post": {
        "summary": "Create a new job listing",
        "tags": ["Admin - Job Listings"],
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/JobListingCreateRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Job listing created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/JobListing" }
              }
            }
          },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized" },
          "429": { "description": "Too many requests" }
        }
      },
      "delete": {
        "summary": "Delete a job listing",
        "tags": ["Admin - Job Listings"],
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "id", "in": "query", "required": true, "description": "Job listing ID", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Job listing deleted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" }
              }
            }
          },
          "400": { "description": "Missing id parameter" },
          "401": { "description": "Unauthorized" },
          "429": { "description": "Too many requests" }
        }
      }
    }
  },
  "defaultResponseSet": "common",
  "responseSets": {
    "common": ["400", "500"],
    "auth": ["400", "401", "403", "500"],
    "public": ["400", "500"]
  },
  "errorConfig": {
    "template": {
      "type": "object",
      "properties": {
        "error": { "type": "string", "example": "{{ERROR_MESSAGE}}" }
      }
    },
    "codes": {
      "400": { "description": "Bad Request" },
      "401": { "description": "Unauthorized" },
      "403": { "description": "Forbidden" },
      "404": { "description": "Not Found" },
      "409": { "description": "Conflict" },
      "429": { "description": "Too Many Requests" },
      "500": { "description": "Internal Server Error" }
    }
  },
  "schemaType": "zod",
  "schemaFiles": ["lib/validations.ts"],
  "docsUrl": "api-docs",
  "ui": "scalar",
  "outputFile": "openapi.json",
  "outputDir": "./public",
  "diagnostics": { "enabled": true },
  "ignoreRoutes": [],
  "debug": false,
  "apiDir": "./app/api",
  "routerType": "app",
  "schemaDir": "./",
  "framework": {
    "kind": "nextjs",
    "router": "app"
  },
  "next": {},
  "includeOpenApiRoutes": false
}
